{
  "name": "prism",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Auth Permission Engine — the immune system for autonomous AI agents",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./langchain": {
      "import": "./dist/langchain/index.mjs",
      "require": "./dist/langchain/index.js",
      "types": "./dist/langchain/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./express": {
      "import": "./dist/express/index.mjs",
      "require": "./dist/express/index.js",
      "types": "./dist/express/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "auth",
    "authorization",
    "ai-agents",
    "langchain",
    "permissions",
    "jwt",
    "confidence-aware"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "express": ">=4"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "express": { "optional": true }
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "express": "^4.19.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prism/auth-permission-engine.git",
    "directory": "sdk/typescript"
  }
}
