{
  "name": "lelu-agent-auth",
  "version": "0.0.12",
  "description": "TypeScript SDK for Lelu — the authorization engine for autonomous AI agents",
  "author": "Abenezer Getachew",
  "contributors": [
    {
      "name": "Abenezer Getachew",
      "url": "https://github.com/Abenezer0923"
    }
  ],
  "homepage": "https://lelu-ai.com/",
  "bugs": {
    "url": "https://github.com/lelu-auth/lelu/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "lelu": "./scripts/lelu.js",
    "lelu-init": "./scripts/init.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./langchain": {
      "types": "./dist/langchain/index.d.ts",
      "import": "./dist/langchain/index.mjs",
      "require": "./dist/langchain/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./express": {
      "types": "./dist/express/index.d.ts",
      "import": "./dist/express/index.mjs",
      "require": "./dist/express/index.js"
    }
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "npm run build:sdk",
    "build:sdk": "tsup",
    "build:ui": "node scripts/build-ui.js",
    "build:all": "npm run build:sdk && npm run build:ui",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build:sdk"
  },
  "keywords": [
    "auth",
    "authorization",
    "ai-agents",
    "langchain",
    "permissions",
    "jwt",
    "confidence-aware"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/react": "^3.0.99",
    "ai": "^6.0.97",
    "better-sqlite3": "^11.0.0",
    "openai": "^6.22.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "express": ">=4",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "express": "^4.19.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lelu-auth/lelu.git",
    "directory": "sdk/typescript"
  }
}
