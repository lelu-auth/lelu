# Vercel Environment Variables for Lelu Frontend
# Copy these to your Vercel Project Settings → Environment Variables

# ─── Lelu Engine (Hosted on Render) ──────────────────────────────────────────
LELU_ENGINE_URL=https://lelu-engine.onrender.com
LELU_BASE_URL=https://lelu-engine.onrender.com

# Get this from Render Dashboard → lelu-engine → Environment → API_KEY
LELU_API_KEY=your-api-key-from-render

# ─── Optional: Platform API ──────────────────────────────────────────────────
PLATFORM_URL=https://lelu-engine.onrender.com
PLATFORM_API_KEY=your-platform-api-key

# ─── Next.js Configuration ───────────────────────────────────────────────────
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# ─── Instructions ─────────────────────────────────────────────────────────────
# 1. Go to Vercel Dashboard → Your Project → Settings → Environment Variables
# 2. Add each variable above
# 3. Set for: Production, Preview, and Development
# 4. Redeploy your project
