# ─── Prism Engine ─────────────────────────────────────────────────────────────
# HTTP server listen address
LISTEN_ADDR=:8080

# Path to the YAML policy file loaded at startup
POLICY_PATH=./config/auth.yaml

# Redis address for token revocation store (leave empty to disable Redis)
REDIS_ADDR=localhost:6379

# HMAC secret used to sign JIT JWTs — CHANGE THIS before production
JWT_SIGNING_KEY=change-me-in-development

# ─── Control Plane (optional) ─────────────────────────────────────────────────
# URL of the central policy control plane for hot-reload
CONTROL_PLANE_URL=

# HMAC secret used to verify control-plane policy payloads
CP_HMAC_SECRET=

# Optional OPA/Rego policy mode (if set, Rego is used in addition to YAML)
REGO_POLICY_PATH=
REGO_POLICY_QUERY=data.prism.authz

# ─── Platform (Phase 3 control plane) ────────────────────────────────────────
# Postgres DSN for the control plane
DATABASE_URL=postgres://prism:prism-dev-secret@localhost:5432/prism?sslmode=disable

# Password for the local Postgres container (used by docker-compose)
POSTGRES_PASSWORD=prism-dev-secret

# API key the engine uses when pushing audit events to the platform
PLATFORM_API_KEY=platform-dev-key

# Optional Enterprise SSO (OIDC) for control-plane auth
OIDC_ISSUER_URL=
OIDC_AUDIENCE=

# ─── TypeScript SDK ───────────────────────────────────────────────────────────
# Base URL the TS/Python SDK connects to
PRISM_BASE_URL=http://localhost:8080

# Optional API key (if you add key-based auth later)
PRISM_API_KEY=
