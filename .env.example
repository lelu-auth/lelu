# ─── Lelu Engine ─────────────────────────────────────────────────────────────
# HTTP server listen address
LISTEN_ADDR=:8080

# Path to the YAML policy file loaded at startup
POLICY_PATH=./config/auth.yaml

# Redis address for token revocation store (leave empty to disable Redis)
REDIS_ADDR=localhost:6379

# HMAC secret used to sign JIT JWTs — CHANGE THIS before production
JWT_SIGNING_KEY=change-me-in-development

# ─── Control Plane (optional) ─────────────────────────────────────────────────
# URL of the central policy control plane for hot-reload
CONTROL_PLANE_URL=

# HMAC secret used to verify control-plane policy payloads
CP_HMAC_SECRET=

# Optional OPA/Rego policy mode (if set, Rego is used in addition to YAML)
REGO_POLICY_PATH=
REGO_POLICY_QUERY=data.lelu.authz

# ─── Platform (Phase 3 control plane) ────────────────────────────────────────
# Postgres DSN for the control plane
DATABASE_URL=postgres://lelu:lelu-dev-secret@localhost:5432/lelu?sslmode=disable

# Password for the local Postgres container (used by docker-compose)
POSTGRES_PASSWORD=lelu-dev-secret

# API key the engine uses when pushing audit events to the platform
PLATFORM_API_KEY=platform-dev-key

# Optional Enterprise SSO (OIDC) for control-plane auth
OIDC_ISSUER_URL=
OIDC_AUDIENCE=

# Optional trusted SSO proxy header fallback (for SAML/ingress-auth setups)
SSO_TRUSTED_HEADER=
SSO_TRUSTED_EMAIL_DOMAIN=

# ─── TypeScript SDK / Frontend ───────────────────────────────────────────────
# Base URL the SDK connects to
# For production (hosted engine):
LELU_BASE_URL=https://lelu-engine.onrender.com
# For local development:
# LELU_BASE_URL=http://localhost:8080

# Engine URL (alternative name for frontend)
LELU_ENGINE_URL=https://lelu-engine.onrender.com

# API key from Render Dashboard (Engine → Environment → API_KEY)
LELU_API_KEY=your-api-key-here

# Optional Platform API (if deployed)
PLATFORM_URL=https://lelu-engine.onrender.com
PLATFORM_API_KEY=your-platform-api-key-here
