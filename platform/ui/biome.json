{
  "$schema": "https://biomejs.dev/schemas/1.7.0/schema.json",
  "organizeImports": {
    "enabled": true
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "ignore": ["dist/*", "node_modules/*", ".next/*", "coverage/*", "build/*"]
  },
  "files": {
    "maxSize": 2097152,
    "ignore": [
      "dist/*",
      "node_modules/*",
      ".next/*",
      "*.config.json",
      "tsconfig*.json",
      "src/routeTree.gen.ts",
      "public/assets/**/*.css",
      "public/assets/**/*.js"
    ]
  }
}
